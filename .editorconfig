root = true

[*.{md,mdx,txt,yml,yaml,rs,py,js,ts,html,css,scss,sh}]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[{Dockerfile,Makefile,Cargo.toml}]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 2

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

[*.bat]
end_of_line = crlf
